  },
  "database_support_matrix": [
    {
      "database": "PostgreSQL",
      "supported_versions": {
        "minimum": "10.0",
        "recommended": "18.3+"
      },
      "technical_notes": [
        "Supports JSONB",
        "Supports UUID",
        "Supports Geometry"
      ]
    },
    {
      "database": "SQL Server",
      "supported_versions": {
        "minimum": "2012",
        "recommended": "2022+"
      },
      "technical_notes": [
        "Supports DateTime2",
        "Supports DateTimeOffset",
        "Optimized for high precision datetime handling"
      ]
    },
    {
      "database": "MySQL",
      "supported_versions": {
        "minimum": "5.7",
        "recommended": "8.0+"
      },
      "technical_notes": [
        "Supports JSON datatype",
        "Supports TinyInt(1) for boolean/logical values"
      ]
    },
    {
      "database": "Oracle",
      "supported_versions": {
        "minimum": "11g",
        "recommended": "23c"
      },
      "technical_notes": [
        "Supports SDO_GEOMETRY",
        "Supports VARCHAR2",
        "Designed for Oracle modern stack compatibility"
      ]
    }
  ],
